{
  "name": "ploppytv",
  "version": "1.2.0",
  "description": "PloppyTV - Tracker personale per serie TV (PWA)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.js,.cjs,.mjs --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.js,.cjs,.mjs --fix",
    "format": "prettier --write \"src/**/*.{ts,css,html}\" \"*.json\" \"!package-lock.json\"",
    "format:check": "prettier --check \"src/**/*.{ts,css,html}\" \"*.json\" \"!package-lock.json\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^24.1.3",
    "lint-staged": "^15.5.2",
    "prettier": "^3.9.4",
    "typescript": "^5.6.3",
    "typescript-eslint": "^7.18.0",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^1.6.1"
  }
}
