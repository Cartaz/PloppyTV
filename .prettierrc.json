{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "bracketSpacing": true,
  "overrides": [
    {
      "files": "*.md",
      "options": { "printWidth": 100, "proseWrap": "preserve" }
    },
    {
      "files": "*.json",
      "options": { "tabWidth": 2 }
    }
  ]
}
